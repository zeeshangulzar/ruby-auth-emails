<!DOCTYPE html>
<html>
  <body style="font-family:sans-serif;max-width:600px;margin:0 auto;padding:2rem;color:#333;">
    <h2>Confirm your email address</h2>
    <p>Hi <%= @email %>,</p>
    <p>Thanks for signing up! Click the button below to confirm your email address and activate your account.</p>

    <p style="margin:2rem 0;">
      <%= link_to "Confirm my account",
            confirmation_url(@resource, confirmation_token: @token),
            style: "background:#4f46e5;color:#fff;padding:0.75rem 1.5rem;border-radius:6px;text-decoration:none;display:inline-block;" %>
    </p>

    <p style="color:#666;font-size:0.875rem;">
      This link expires in <%= Devise.confirm_within.inspect.gsub("2 days", "48 hours") rescue "48 hours" %>.
      If you didn't create an account, you can safely ignore this email.
    </p>
  </body>
</html>
